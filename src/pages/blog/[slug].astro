---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} · TodoTítulo`} description={post.data.description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "author": {
    "@type": "Person",
    "name": "José Ignacio Torrontegui",
    "jobTitle": "Abogado",
    "knowsAbout": [
      "Compraventa de propiedades en Chile",
      "Estudio de títulos y Conservador de Bienes Raíces",
      "Posesión efectiva e impuesto a la herencia",
      "Juicio de partición de bienes",
      "Desahucio y juicio de arrendamiento",
      "Ley Devuélveme mi casa",
      "Acción de precario",
      "Regularización de títulos de dominio",
      "Saneamiento de propiedades rurales",
      "Regularización de construcciones DOM",
      "Usufructo vitalicio",
      "Sociedades familiares",
      "Remates judiciales",
      "Derecho Inmobiliario Chile",
      "Derecho Sucesorio Chile"
    ],
    "url": "https://todotitulo.cl"
  },
  "publisher": {
    "@type": "Organization",
    "name": "TodoTítulo",
    "url": "https://todotitulo.cl"
  },
  "mainEntityOfPage": `https://todotitulo.cl/blog/${post.id.replace(/\.md$/, '')}`
})} />

<style>
  .article-wrap {
    max-width: 820px;
    margin: 0 auto;
    padding: 9rem 1.5rem 5rem;
    position: relative; z-index: 2;
  }
  .article-eyebrow {
    font-size: .72rem; font-weight: 400;
    letter-spacing: .15em; text-transform: uppercase;
    color: var(--o);
    display: flex; align-items: center; gap: .75rem;
    margin-bottom: 1.5rem;
  }
  .article-eyebrow::before { content: ''; width: 32px; height: 1px; background: var(--o); }
  .article-wrap h1 {
    font-family: var(--fd);
    font-size: clamp(2.1rem, 5vw, 3.2rem);
    font-weight: 200; line-height: 1.15;
    color: var(--p); margin-bottom: 1.5rem;
  }
  .article-meta {
    font-size: .85rem; color: var(--g);
    border-bottom: 1px solid rgba(245,240,232,.08);
    padding-bottom: 2rem; margin-bottom: 2.5rem;
  }

  /* Article body */
  .article-body { color: rgba(245,240,232,.82); }
  .article-body :global(p) { margin-bottom: 1.5rem; font-size: 1.05rem; line-height: 1.85; }
  .article-body :global(h2) {
    font-family: var(--fd);
    font-size: 1.7rem; font-weight: 300;
    color: var(--p); margin: 2.8rem 0 1.2rem; line-height: 1.25;
  }
  .article-body :global(h3) {
    font-family: var(--fd);
    font-size: 1.3rem; font-weight: 300;
    color: var(--p); margin: 2rem 0 .8rem;
  }
  .article-body :global(strong) { color: var(--p); font-weight: 400; }
  .article-body :global(em) { font-style: italic; }

  /* Nota */
  .article-body :global(.nota) {
    background: rgba(245,240,232,.06);
    border-left: 3px solid var(--o);
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
    font-size: .98rem;
    color: rgba(245,240,232,.65);
  }

  /* Callout (fórmula) */
  .article-body :global(.callout) {
    background: rgba(245,240,232,.05);
    border: 1px solid rgba(245,240,232,.1);
    padding: 1.5rem;
    margin: 2rem 0;
    font-size: .95rem;
    line-height: 1.9;
    color: rgba(245,240,232,.7);
  }

  /* CTA */
  .article-cta {
    background: rgba(245,240,232,.05);
    border: 1px solid rgba(245,240,232,.08);
    padding: 2.5rem;
    margin-top: 3rem;
    text-align: center;
  }
  .article-cta h3 {
    font-family: var(--fd);
    font-size: 1.6rem; font-weight: 200;
    color: var(--p); margin-bottom: .8rem;
  }
  .article-cta p { color: rgba(245,240,232,.55); margin-bottom: 1.5rem; font-size: .9rem; }
  .article-cta a {
    display: inline-block;
    background: var(--o); color: var(--p);
    text-decoration: none;
    padding: .9rem 2rem;
    font-size: .82rem; font-weight: 400;
    letter-spacing: .08em; text-transform: uppercase;
    transition: background .2s;
  }
  .article-cta a:hover { background: var(--o2); }

  /* Author bio */
  .author-bio {
    display: flex; align-items: center; gap: 1.25rem;
    border-top: 1px solid rgba(245,240,232,.08);
    margin-top: 3rem; padding-top: 2rem;
  }
  .author-avatar {
    width: 52px; height: 52px; border-radius: 50%;
    background: rgba(245,240,232,.08);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    font-family: var(--fd); font-size: 1.3rem; font-weight: 300;
    color: var(--p);
  }
  .author-info { font-size: .9rem; color: var(--g); line-height: 1.5; }
  .author-info strong { display: block; color: var(--p); font-size: .95rem; margin-bottom: .2rem; }
  .author-info a { color: var(--o); text-decoration: none; }

  .back-link {
    display: inline-block; margin-top: 2.5rem;
    color: var(--g); text-decoration: none; font-size: .9rem;
    transition: color .3s;
  }
  .back-link:hover { color: var(--o); }
</style>

<div class="article-wrap">
  <p class="article-eyebrow">{post.data.category}</p>
  <h1>{post.data.title}</h1>
  <div class="article-meta">Guía práctica · TodoTítulo</div>

  <div class="article-body">
    <Content />
  </div>

  <div class="article-cta">
    <h3>¿Tienes un caso relacionado?</h3>
    <p>La evaluación del caso no tiene costo.</p>
    <a href="/#contacto">Cuéntanos tu caso</a>
  </div>

  <div class="author-bio">
    <div class="author-avatar">JT</div>
    <div class="author-info">
      <strong>José Ignacio Torrontegui</strong>
      Abogado en Derecho Inmobiliario y Sucesorio · <a href="/#contacto">Consulta sin costo</a>
    </div>
  </div>

  <a href="/guias" class="back-link">← Volver a Guías</a>
</div>

</Layout>
