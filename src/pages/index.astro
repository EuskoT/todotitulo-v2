---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="TodoTítulo · Asesoría Jurídica Inmobiliaria y Sucesoria"
  description="Resuelve tus problemas de propiedad sin salir de ella. Derecho Inmobiliario y Sucesorio en Chile. Evaluación del caso sin costo, atención 100% remota."
>

<style>
  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; align-items: center;
    padding: 0 5rem;
    position: relative; z-index: 2;
    background: radial-gradient(120% 70% at 80% -5%, color-mix(in oklab, var(--accent) 14%, transparent) 0%, transparent 55%);
  }
  .hero-inner { max-width: 1200px; }
  .htag {
    font-family: var(--font-mono);
    font-size: var(--fs-xs); font-weight: var(--fw-medium);
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--text-accent);
    margin-bottom: 2.5rem;
  }

  .hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8.5vw, 8rem);
    font-weight: var(--fw-light); line-height: 1;
    color: var(--text-strong); margin-bottom: 3rem;
  }
  .hero h1 .ln { display: block; }
  .hero h1 em { font-style: italic; color: var(--accent); }

  .hmeta { display: flex; gap: 4rem; align-items: flex-start; }
  .hmeta-in { display: flex; gap: 4rem; }
  .hmeta p {
    font-size: var(--fs-sm); font-weight: var(--fw-regular);
    line-height: 1.9; color: var(--text-body);
    max-width: 380px;
  }
  .hcta {
    display: inline-flex; align-items: center; gap: .8rem;
    color: var(--text-strong); text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--fs-xs); letter-spacing: var(--ls-eyebrow); text-transform: uppercase;
    white-space: nowrap; padding-bottom: 4px;
    border-bottom: 1px solid var(--accent);
    transition: gap .3s var(--ease2);
  }
  .hcta:hover { gap: 1.4rem; }
  .hcta .ar { color: var(--accent); }

  .hbig {
    position: absolute; bottom: -2vw; left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-serif);
    font-size: clamp(90px, 15vw, 200px);
    font-weight: var(--fw-light); font-style: italic;
    color: color-mix(in oklab, var(--text-strong) 2.5%, transparent);
    pointer-events: none; user-select: none;
    z-index: -1; line-height: .82; text-align: center;
    white-space: nowrap;
  }

  /* SECCIONES */
  .sec { padding: 11rem 5rem; position: relative; z-index: 2; }

  /* SERVICIOS */
  .sv { background: var(--surface-cream); }
  .sv-list { border-top: 1px solid var(--border-hairline); }
  .sv-item {
    border-bottom: 1px solid var(--border-hairline);
    position: relative;
  }
  .sv-item::before {
    content: ''; position: absolute;
    left: 0; top: 0; bottom: 0; width: 2px;
    background: var(--accent);
    transform: scaleY(0); transform-origin: top;
    transition: transform .5s var(--ease2);
  }
  .sv-item.open::before { transform: scaleY(1); }
  .sv-head {
    display: flex; align-items: center; gap: 2rem;
    padding: 2.4rem 0 2.4rem 2rem;
    cursor: pointer;
    transition: padding-left .4s var(--ease2);
  }
  .sv-item.open .sv-head { padding-left: 3rem; }
  .sv-num {
    font-family: var(--font-mono);
    font-size: var(--fs-xs); letter-spacing: var(--ls-eyebrow);
    color: var(--text-accent); width: 2rem; flex-shrink: 0;
  }
  .sv-name {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3.6vw, 3.2rem);
    font-weight: var(--fw-light); font-style: italic;
    color: var(--text-strong);
    flex: 1; line-height: 1.05; transition: color .3s;
  }
  .sv-item:hover .sv-name { color: var(--accent); }
  .sv-x { width: 18px; height: 18px; position: relative; flex-shrink: 0; }
  .sv-x::before, .sv-x::after {
    content: ''; position: absolute; background: var(--accent);
    transition: transform .4s var(--ease2);
  }
  .sv-x::before { top: 50%; left: 0; right: 0; height: 1px; transform: translateY(-50%); }
  .sv-x::after  { left: 50%; top: 0; bottom: 0; width: 1px; transform: translateX(-50%); }
  .sv-item.open .sv-x::after { transform: translateX(-50%) scaleY(0); }
  .sv-body { max-height: 0; overflow: hidden; transition: max-height .55s var(--ease2); }
  .sv-item.open .sv-body { max-height: 220px; }
  .sv-body p {
    font-size: var(--fs-sm); line-height: 1.95;
    color: var(--text-body); padding: 0 0 2.4rem 4rem; max-width: 620px;
  }

  /* PROCESO */
  .pr { background: var(--surface-card); }
  .pr-grid {
    display: grid; grid-template-columns: repeat(5, 1fr);
    gap: 0; border-top: 1px solid var(--border-hairline);
  }
  .pr-item { padding: 2.5rem 1.5rem 0 0; position: relative; }
  .pr-item::before {
    content: ''; position: absolute;
    top: -1px; left: 0; width: 0; height: 1px;
    background: var(--accent); transition: width .8s var(--ease2);
  }
  .pr-item.vis::before { width: 100%; }
  .pr-n {
    font-family: var(--font-serif);
    font-size: 2.4rem; font-weight: var(--fw-light);
    color: color-mix(in oklab, var(--accent) 25%, transparent);
    line-height: 1; margin-bottom: 1.4rem;
  }
  .pr-item h3 {
    font-family: var(--font-serif); font-size: 1.3rem;
    font-weight: var(--fw-light); font-style: italic;
    color: var(--text-strong); margin-bottom: .6rem;
  }
  .pr-item p { font-size: var(--fs-xs); color: var(--text-muted); line-height: 1.75; }

  /* POR QUÉ */
  .pq { background: var(--surface-sunken); }
  .pq-inner { display: grid; grid-template-columns: 1fr 1.8fr; gap: 7rem; }
  .pq-left h2 {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4vw, 3.6rem);
    font-weight: var(--fw-light); font-style: italic; line-height: 1.08;
    color: var(--text-strong);
    position: sticky; top: 8rem;
  }
  .pq-right { display: flex; flex-direction: column; }
  .pq-item {
    padding: 2.4rem 0; border-bottom: 1px solid var(--border-hairline);
    display: grid; grid-template-columns: auto 1fr;
    gap: 2rem; align-items: baseline;
  }
  .pq-item:first-child { border-top: 1px solid var(--border-hairline); }
  .pq-c {
    font-family: var(--font-mono);
    font-size: var(--fs-xs); letter-spacing: var(--ls-eyebrow);
    color: var(--text-accent);
  }
  .pq-item h3 {
    font-family: var(--font-serif); font-size: 1.3rem;
    font-weight: var(--fw-regular); margin-bottom: .4rem;
    color: var(--text-strong);
  }
  .pq-item p { font-size: var(--fs-sm); color: var(--text-body); line-height: 1.85; }

  /* CONTACTO */
  .co { background: var(--surface-cream); }
  .co-inner { display: grid; grid-template-columns: 1fr 1.1fr; gap: 7rem; align-items: start; }
  .co-info h2 {
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 5vw, 4.4rem);
    font-weight: var(--fw-light); font-style: italic;
    color: var(--text-strong);
    line-height: 1; margin-bottom: 2rem;
  }
  .co-info > p {
    font-size: var(--fs-sm); color: var(--text-body);
    line-height: 1.95; margin-bottom: 2.5rem; max-width: 370px;
  }
  .co-dato { margin-bottom: 1.3rem; }
  .co-dato .dl {
    font-family: var(--font-mono);
    font-size: var(--fs-xs); letter-spacing: var(--ls-eyebrow); text-transform: uppercase;
    color: var(--text-accent); margin-bottom: .25rem;
  }
  .co-dato a {
    font-size: var(--fs-sm); color: var(--text-body);
    text-decoration: none; position: relative;
  }
  .co-dato a::after {
    content: ''; position: absolute;
    left: 0; bottom: -2px; width: 100%; height: 1px;
    background: var(--accent); transform: scaleX(0); transform-origin: right;
    transition: transform .4s var(--ease2);
  }
  .co-dato a:hover::after { transform: scaleX(1); transform-origin: left; }
  .cal-btn {
    display: inline-flex; align-items: center; gap: 0.75rem;
    background: transparent; color: var(--text-body);
    font-family: var(--font-sans);
    font-weight: var(--fw-regular); font-size: var(--fs-xs); letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase; text-decoration: none;
    padding: 0.9rem 1.75rem; margin-bottom: 1.5rem;
    border: 1px solid var(--accent); border-radius: var(--radius-sm);
    transition: background 0.2s, color 0.2s;
  }
  .cal-btn::before {
    content: ''; display: inline-block;
    width: 14px; height: 14px;
    border: 1px solid var(--accent); border-radius: var(--radius-xs); flex-shrink: 0;
  }
  .cal-btn:hover { background: var(--accent); color: var(--accent-contrast); }
  .wa-btn {
    display: inline-flex; align-items: center; gap: 0.75rem;
    background: transparent; color: var(--text-body);
    font-family: var(--font-sans);
    font-weight: var(--fw-regular); font-size: var(--fs-xs); letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase; text-decoration: none;
    padding: 0.9rem 1.75rem; margin-bottom: 1.5rem;
    border: 1px solid var(--accent); border-radius: var(--radius-sm);
    transition: background 0.2s, color 0.2s;
  }
  .wa-btn svg { fill: #25D366; flex-shrink: 0; transition: fill 0.2s; }
  .wa-btn:hover { background: var(--accent); color: var(--accent-contrast); }
  .wa-btn:hover svg { fill: var(--accent-contrast); }
  .ff { margin-bottom: 1.6rem; }
  .ff label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--fs-xs); letter-spacing: var(--ls-eyebrow); text-transform: uppercase;
    color: var(--text-muted); margin-bottom: .5rem;
  }
  .ff input, .ff select, .ff textarea {
    width: 100%; background: transparent;
    border: none; border-bottom: 1px solid var(--border-default);
    padding: .6rem 0; font-family: var(--font-sans);
    font-weight: var(--fw-regular); font-size: var(--fs-sm); color: var(--text-body);
    outline: none; transition: border-color .4s var(--ease2);
    -webkit-appearance: none; border-radius: 0;
  }
  .ff input:focus, .ff select:focus, .ff textarea:focus { border-bottom-color: var(--accent); }
  .ff input::placeholder, .ff textarea::placeholder { color: var(--text-subtle); }
  .ff textarea { resize: none; height: 74px; }
  .fsub {
    width: 100%; padding: 1.05rem;
    background: var(--accent); color: var(--accent-contrast); border: none;
    cursor: pointer; font-family: var(--font-sans);
    font-weight: var(--fw-medium); font-size: var(--fs-xs);
    letter-spacing: var(--ls-eyebrow); text-transform: uppercase;
    border-radius: var(--radius-sm);
    transition: background .4s var(--ease2); margin-top: .6rem;
  }
  .fsub:hover { background: var(--accent-hover); }

  /* MOBILE */
  @media (max-width: 860px) {
    .hero { padding: 7rem 1.5rem 4rem; }
    .sec { padding: 6rem 1.5rem; }
.hmeta-in { flex-direction: column; gap: 2rem; }
    .pr-grid { grid-template-columns: 1fr 1fr; row-gap: 2.5rem; }
    .pq-inner, .co-inner { grid-template-columns: 1fr; gap: 3rem; }
    .pq-left h2 { position: static; }
  }

  /* ── Dark mode: hex !important — ningún token puede sobrescribir ── */
  /* HERO */
  [data-theme="dark"] .hero h1            { color: #f6f1e9 !important; }
  [data-theme="dark"] .hmeta p            { color: #ece5da !important; }
  [data-theme="dark"] .hcta               { color: #f6f1e9 !important; }
  /* SERVICIOS */
  [data-theme="dark"] .sv-name            { color: #f6f1e9 !important; }
  [data-theme="dark"] .sv-body p          { color: #ece5da !important; }
  /* PROCESO */
  [data-theme="dark"] .pr-item h3         { color: #f6f1e9 !important; }
  [data-theme="dark"] .pr-item p          { color: #aaa297 !important; }
  /* POR QUÉ */
  [data-theme="dark"] .pq-left h2         { color: #f6f1e9 !important; }
  [data-theme="dark"] .pq-item h3         { color: #f6f1e9 !important; }
  [data-theme="dark"] .pq-item p          { color: #ece5da !important; }
  /* CONTACTO */
  [data-theme="dark"] .co-info h2         { color: #f6f1e9 !important; }
  [data-theme="dark"] .co-info > p        { color: #ece5da !important; }
  [data-theme="dark"] .co-dato a          { color: #ece5da !important; }
  [data-theme="dark"] .cal-btn            { color: #ece5da !important; }
  [data-theme="dark"] .wa-btn             { color: #ece5da !important; }
  [data-theme="dark"] .ff label           { color: #aaa297 !important; }
  [data-theme="dark"] .ff input,
  [data-theme="dark"] .ff select,
  [data-theme="dark"] .ff textarea         { color: #ece5da !important; }
</style>

<!-- HERO -->
<section class="hero" id="inicio">
  <div class="hbig"><span>Todo</span><br><span>Título</span></div>
  <div class="hero-inner">
    <p class="htag">Asesoría Jurídica · Inmobiliaria &amp; Sucesoria</p>
    <h1>
      <span class="ln">Resuelve tus problemas</span>
      <span class="ln">de propiedad <em>sin salir de ella.</em></span>
    </h1>
    <div class="hmeta">
      <div class="hmeta-in">
        <p>Desde compraventas a herencias. Evaluación del caso sin costo, un solo abogado de principio a fin. Atención online en todo Chile, presencial en Santiago.</p>
        <a href="#contacto" class="hcta" data-cur>Cuéntanos tu caso <span class="ar">→</span></a>
      </div>
    </div>
  </div>
</section>

<!-- SERVICIOS -->
<section class="sec sv" id="servicios">
  <p class="section-label rv">Servicios</p>
  <div class="sv-list">
    <div class="sv-item rv">
      <div class="sv-head" data-cur>
        <span class="sv-num">01</span>
        <span class="sv-name">Quiero comprar o vender una propiedad</span>
        <span class="sv-x"></span>
      </div>
      <div class="sv-body"><p>Revisamos el historial de la propiedad en el Conservador de Bienes Raíces para asegurarnos de que esté libre de hipotecas, embargos o litigios pendientes. Redactamos y revisamos promesas, escrituras y contratos. Si estás en un remate, te acompañamos desde la evaluación inicial hasta la escritura final.</p></div>
    </div>
    <div class="sv-item rv">
      <div class="sv-head" data-cur>
        <span class="sv-num">02</span>
        <span class="sv-name">Falleció un familiar y hay bienes que repartir</span>
        <span class="sv-x"></span>
      </div>
      <div class="sv-body"><p>Tramitamos la posesión efectiva, con o sin testamento, y gestionamos el impuesto a la herencia ante el SII. Si los herederos no se ponen de acuerdo, te representamos en el juicio de partición. Si quieren llegar a un acuerdo, redactamos la escritura de adjudicación sin necesidad de ir a tribunales.</p></div>
    </div>
    <div class="sv-item rv">
      <div class="sv-head" data-cur>
        <span class="sv-num">03</span>
        <span class="sv-name">Tengo un arrendatario o un ocupante que no se va</span>
        <span class="sv-x"></span>
      </div>
      <div class="sv-body"><p>Recuperamos tu propiedad. Gestionamos juicios de arrendamiento por no pago aplicando la ley "Devuélveme mi casa", y también demandas de precario para ocupantes sin contrato ni título. Sabemos lo que implica negociar con quien no quiere salir, y también demandarlo cuando no queda otra.</p></div>
    </div>
    <div class="sv-item rv">
      <div class="sv-head" data-cur>
        <span class="sv-num">04</span>
        <span class="sv-name">Mi propiedad tiene problemas con su título</span>
        <span class="sv-x"></span>
      </div>
      <div class="sv-body"><p>Regularizamos títulos de dominio ante el Ministerio de Bienes Nacionales y gestionamos la regularización de construcciones ante la DOM municipal. Títulos deficientes, inscripciones omitidas y saneamiento de propiedades rurales.</p></div>
    </div>
    <div class="sv-item rv">
      <div class="sv-head" data-cur>
        <span class="sv-num">05</span>
        <span class="sv-name">Quiero ordenar mi patrimonio en vida y definir su futuro</span>
        <span class="sv-x"></span>
      </div>
      <div class="sv-body"><p>Esto puede incluir la redacción de testamentos, usufructos vitalicios que permiten traspasar la propiedad a los hijos conservando el uso de por vida, o la creación de sociedades familiares para organizar los bienes de forma ordenada.</p></div>
    </div>
    <div class="sv-item rv">
      <div class="sv-head" data-cur>
        <span class="sv-num">06</span>
        <span class="sv-name">Compré en un remate y necesito regularizar</span>
        <span class="sv-x"></span>
      </div>
      <div class="sv-body"><p>Gestionamos el proceso legal completo de adquisición y coordinamos, junto a profesionales colaboradores, la regularización, reparación y venta de la propiedad.</p></div>
    </div>
  </div>
</section>

<!-- PROCESO -->
<section class="sec pr" id="proceso">
  <p class="section-label rv">Cómo trabajamos</p>
  <div class="pr-grid">
    <div class="pr-item rv"><div class="pr-n">01</div><h3>Cuéntanos</h3><p>Sin costo y sin compromiso, por formulario o WhatsApp.</p></div>
    <div class="pr-item rv"><div class="pr-n">02</div><h3>Documenta</h3><p>Escrituras, certificados, resoluciones. Aunque esté incompleto.</p></div>
    <div class="pr-item rv"><div class="pr-n">03</div><h3>Evaluamos</h3><p>Revisamos tu caso y determinamos si tiene solución jurídica.</p></div>
    <div class="pr-item rv"><div class="pr-n">04</div><h3>Cotizamos</h3><p>Pasos, honorarios y costos exactos antes de empezar.</p></div>
    <div class="pr-item rv"><div class="pr-n">05</div><h3>Ejecutamos</h3><p>Iniciamos y sabrás en todo momento el avance del caso.</p></div>
  </div>
</section>

<!-- POR QUÉ -->
<section class="sec pq" id="porque">
  <div class="pq-inner">
    <div class="pq-left rv">
      <p class="section-label">Por qué elegirnos</p>
      <h2>Abogados reales, sin burocracia innecesaria.</h2>
    </div>
    <div class="pq-right">
      <div class="pq-item rv"><span class="pq-c">01</span><div><h3>100% remoto</h3><p>Operamos en todo Chile por videollamada. No necesitas viajar ni esperar turno en una oficina.</p></div></div>
      <div class="pq-item rv"><span class="pq-c">02</span><div><h3>Consulta sin costo</h3><p>Primero escuchamos tu caso. Realizamos un análisis de factibilidad y luego te proponemos una solución.</p></div></div>
      <div class="pq-item rv"><span class="pq-c">03</span><div><h3>Transparencia de honorarios</h3><p>Conoces el valor exacto antes de firmar cualquier cosa, sin sorpresas al final del proceso.</p></div></div>
      <div class="pq-item rv"><span class="pq-c">04</span><div><h3>Un solo abogado, de principio a fin</h3><p>Quien evalúa tu caso es quien lo lleva hasta el final, sin que tengas que volver a explicar tu situación.</p></div></div>
    </div>
  </div>
</section>

<!-- CONTACTO -->
<section class="sec co" id="contacto">
  <div class="co-inner">
    <div class="co-info rv">
      <p class="section-label">Contacto</p>
      <h2>Cuéntanos<br>tu caso.</h2>
      <p>La evaluación del caso no tiene costo. Completa el formulario o escríbenos directamente por WhatsApp y te respondemos a la brevedad.</p>
      <a href="https://calendly.com/titulotodo/reuniondelcaso" class="cal-btn" target="_blank" rel="noopener">Agendar reunión</a>
      <div class="co-dato"><p class="dl">Correo</p><a href="mailto:contacto@todotitulo.cl" data-cur>contacto@todotitulo.cl</a></div>
      <a href="https://wa.me/56983801966?text=Hola%2C%20quiero%20evaluar%20mi%20caso" class="wa-btn" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.117.554 4.103 1.523 5.826L.057 23.75a.5.5 0 0 0 .609.61l6.053-1.456A11.93 11.93 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.807 9.807 0 0 1-5.001-1.368l-.36-.213-3.714.893.929-3.63-.235-.373A9.786 9.786 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/></svg>
        Escríbenos por WhatsApp
      </a>
      <div class="co-dato"><p class="dl">Oficina</p><a href="#" data-cur>Santa Lucía 150, Piso 7, Santiago</a></div>
    </div>
    <div class="rv">
      <form method="POST" action="https://formspree.io/f/mojzbgje">
        <input type="hidden" name="_next" value="https://todotitulo.cl/gracias" />
        <div class="ff"><label>Nombre</label><input type="text" name="nombre" placeholder="Tu nombre completo"/></div>
        <div class="ff"><label>Correo</label><input type="email" name="email" placeholder="tu@correo.cl"/></div>
        <div class="ff"><label>Teléfono</label><input type="tel" name="telefono" placeholder="+56 9 0000 0000"/></div>
        <div class="ff">
          <label>Tipo de caso</label>
          <select name="caso">
            <option value="">Selecciona una opción</option>
            <option>Compraventa</option>
            <option>Herencia / Posesión efectiva</option>
            <option>Remate judicial</option>
            <option>Desahucio</option>
            <option>Regularización</option>
            <option>Otro</option>
          </select>
        </div>
        <div class="ff"><label>Descripción breve</label><textarea name="mensaje" placeholder="Cuéntanos en pocas palabras qué necesitas resolver"></textarea></div>
        <button class="fsub" data-cur>Enviar consulta</button>
      </form>
    </div>
  </div>
</section>

<script>
  // Servicios acordeón
  document.querySelectorAll('.sv-head').forEach(h => {
    h.addEventListener('click', () => {
      const it = h.parentElement;
      const was = it.classList.contains('open');
      document.querySelectorAll('.sv-item.open').forEach(i => i.classList.remove('open'));
      if (!was) it.classList.add('open');
    });
  });

  // Línea del proceso en scroll
  const obsP = new IntersectionObserver(es => {
    es.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('vis'), i * 150);
        obsP.unobserve(e.target);
      }
    });
  }, { threshold: .2 });
  document.querySelectorAll('.pr-item').forEach(el => obsP.observe(el));
</script>

</Layout>
